<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:shared="clr-namespace:TioUi.Shared;assembly=TioUi"
    xmlns:t="clr-namespace:TioUi.Shared"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="{x:Static shared:Themes.Mirage}">
            <SolidColorBrush
                Color="#282e3b"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="TabBackground" />
            <SolidColorBrush
                Color="#323a4d"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="TabHover" />
            <SolidColorBrush
                Color="#3d465f"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="TabSelected" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>