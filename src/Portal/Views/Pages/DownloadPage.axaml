<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.DownloadPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:controls="clr-namespace:SmoothScroll.Avalonia.Controls;assembly=SmoothScroll.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <controls:ScrollView
            Classes="Flat"
            DockPanel.Dock="Left"
            HorizontalAlignment="Left"
            Margin="7,0,10,10"
            Width="175">
            <tio:NavMenu Margin="0,0,10,0" Theme="{StaticResource FlatScrollBarTheme}">
                <tio:NavMenuItem Header="Java 版">
                    <tio:NavMenuItem Header="游戏本体" />
                    <tio:NavMenuItem Header="模组" />
                    <tio:NavMenuItem Header="整合包" />
                    <tio:NavMenuItem Header="材质包" />
                    <tio:NavMenuItem Header="光影包" />
                    <tio:NavMenuItem Header="数据包" />
                </tio:NavMenuItem>
                <tio:NavMenuItem Header="基岩版">
                    <tio:NavMenuItem Header="游戏本体" />
                    <tio:NavMenuItem Header="行为包" />
                    <tio:NavMenuItem Header="资源包" />
                    <tio:NavMenuItem Header="世界模板" />
                </tio:NavMenuItem>
            </tio:NavMenu>
        </controls:ScrollView>
        <controls:ScrollView Margin="0,0,5,0" MaxWidth="790">
            <TransitioningContentControl Margin="0,10,10,10" />
        </controls:ScrollView>
    </DockPanel>
</UserControl>
