<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.InstanceDetailPage"
    x:DataType="pages:InstanceDetailPageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:controls="clr-namespace:SmoothScroll.Avalonia.Controls;assembly=SmoothScroll.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:instancePages="clr-namespace:Portal.Views.Pages.InstancePages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:Portal.Views.Pages"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <controls:ScrollView
            Classes="Flat"
            DockPanel.Dock="Left"
            Margin="7,0,00,10"
            Width="140">
                <tio:NavMenu
                    Margin="0,0,10,0"
                    Name="NavMenu"
                    Theme="{StaticResource FlatScrollBarTheme}">
                <tio:NavMenuItem
                    Command="{Binding NavigateTypeCommand}"
                    CommandParameter="{x:Type instancePages:Dashboard}"
                    Header="仪表盘"
                    IsSelected="True" />
                    <tio:NavMenuItem IsVisible="{Binding IsJava}"
                        Command="{Binding NavigateTypeCommand}"
                        CommandParameter="{x:Type instancePages:Mods}"
                        Header="模组" />
                    <tio:NavMenuItem IsVisible="{Binding IsJava}"
                        Command="{Binding NavigateTypeCommand}"
                        CommandParameter="{x:Type instancePages:ResourcePacks}"
                        Header="资源包" />
                    <tio:NavMenuItem IsVisible="{Binding IsJava}"
                        Command="{Binding NavigateTypeCommand}"
                        CommandParameter="{x:Type instancePages:ShaderPacks}"
                        Header="光影包" />
                    <tio:NavMenuItem IsVisible="{Binding IsJava}"
                        Command="{Binding NavigateTypeCommand}"
                    CommandParameter="{x:Type instancePages:Saves}"
                    Header="存档" />
                    <tio:NavMenuItem IsVisible="{Binding IsJava}"
                        Command="{Binding NavigateTypeCommand}"
                    CommandParameter="{x:Type instancePages:Screenshots}"
                    Header="截图" />
                    <tio:NavMenuItem IsVisible="{Binding IsJava}"
                        Command="{Binding NavigateTypeCommand}"
                    CommandParameter="{x:Type instancePages:Logs}"
                    Header="日志" />
                    <tio:NavMenuItem IsVisible="{Binding IsBedrock}"
                        Command="{Binding NavigateTypeCommand}"
                        CommandParameter="{x:Type instancePages:BedrockResourcePacks}"
                        Header="资源包" />
                    <tio:NavMenuItem IsVisible="{Binding IsBedrock}"
                        Command="{Binding NavigateTypeCommand}"
                        CommandParameter="{x:Type instancePages:BedrockBehaviorPacks}"
                        Header="行为包" />
                    <tio:NavMenuItem IsVisible="{Binding IsBedrock}"
                        Command="{Binding NavigateTypeCommand}"
                        CommandParameter="{x:Type instancePages:BedrockWorlds}"
                        Header="世界" />
                    <tio:NavMenuItem IsVisible="{Binding IsBedrock}"
                        Command="{Binding NavigateTypeCommand}"
                        CommandParameter="{x:Type instancePages:BedrockWorldTemplates}"
                        Header="世界模板" />
                    <tio:NavMenuItem IsVisible="{Binding IsBedrock}"
                        Command="{Binding NavigateTypeCommand}"
                        CommandParameter="{x:Type instancePages:BedrockSkins}"
                        Header="皮肤包" />
                    <tio:NavMenuItem IsVisible="{Binding IsBedrock}"
                        Command="{Binding NavigateTypeCommand}"
                        CommandParameter="{x:Type instancePages:Screenshots}"
                        Header="截图" />
                    <tio:NavMenuItem IsVisible="{Binding IsJava}"
                        Command="{Binding NavigateTypeCommand}"
                    CommandParameter="{x:Type instancePages:ConfigFiles}"
                    Header="配置文件" />
                <tio:NavMenuItem
                    Command="{Binding NavigateTypeCommand}"
                    CommandParameter="{x:Type instancePages:Properties}"
                    Header="配置管理" />
            </tio:NavMenu>
        </controls:ScrollView>
        <Rectangle
            DockPanel.Dock="Left"
            Fill="{DynamicResource TranslucentBorderBrush}"
            Margin="0,0,0,10"
            Width="1" />
        <TransitioningContentControl Content="{Binding CurrentPage}" Margin="12,3,12,0">
            <TransitioningContentControl.PageTransition>
                <CrossFade Duration="0:0:0.2" />
            </TransitioningContentControl.PageTransition>
        </TransitioningContentControl>
    </DockPanel>
</UserControl>
