<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.InstancesPage"
    x:DataType="pages:InstancesPageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:classes="clr-namespace:Portal.Core.Minecraft.Classes;assembly=Portal.Core"
    xmlns:controls="clr-namespace:SmoothScroll.Avalonia.Controls;assembly=SmoothScroll.Avalonia.Controls"
    xmlns:converters="clr-namespace:Portal.Module.Converter;assembly=Portal"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:Portal.Views.Pages"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <converters:WidthToColumnsConverter x:Key="WidthToColumnsConv" />
    </UserControl.Resources>
    <DockPanel Margin="12,0,0,10">
        <Panel DockPanel.Dock="Top" Margin="0,0,12,10">
            <StackPanel
                HorizontalAlignment="Left"
                Margin="5,0,0,0"
                Orientation="Horizontal"
                Spacing="10"
                VerticalAlignment="Bottom">
                <TextBlock
                    FontSize="12"
                    Foreground="{DynamicResource InnerForegroundColor}"
                    Margin="5,0,0,0"
                    Text="{Binding SummaryText}" />
                <Button
                    Click="RefreshInstance_Click"
                    Theme="{StaticResource TransparentButton}"
                    VerticalAlignment="Center">
                    <PathIcon
                        Data="F1 M640,640z M0,0z M500.7,138.7L512,149.4 512,96C512,78.3 526.3,64 544,64 561.7,64 576,78.3 576,96L576,224C576,241.7,561.7,256,544,256L416,256C398.3,256 384,241.7 384,224 384,206.3 398.3,192 416,192L463.9,192 456.3,184.8C456.1,184.6 455.9,184.4 455.7,184.2 380.7,109.2 259.2,109.2 184.2,184.2 109.2,259.2 109.2,380.7 184.2,455.7 259.2,530.7 380.7,530.7 455.7,455.7 463.9,447.5 471.2,438.8 477.6,429.6 487.7,415.1 507.7,411.6 522.2,421.7 536.7,431.8 540.2,451.8 530.1,466.3 521.6,478.5 511.9,490.1 501,501 401,601 238.9,601 139,501 39.1,401 39,239 139,139 238.9,39.1 400.7,39 500.7,138.7z"
                        Foreground="{DynamicResource InnerForegroundColor}"
                        Height="16"
                        Width="16" />
                </Button>
            </StackPanel>
            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <ComboBox
                    ItemsSource="{Binding FolderFilterOptions}"
                    SelectedItem="{Binding SelectedFolderFilter}"
                    Width="175">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                MaxWidth="120"
                                Text="{Binding DisplayText}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSortOption}"
                    Width="120">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayText}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBox
                    PlaceholderText="搜索"
                    Text="{Binding SearchText}"
                    Width="170">
                    <TextBox.InnerRightContent>
                        <PathIcon
                            Data="F1 M512,512z M0,0z M416,208C416,253.9,401.1,296.3,376,330.7L502.6,457.4C515.1,469.9 515.1,490.2 502.6,502.7 490.1,515.2 469.8,515.2 457.3,502.7L330.7,376C296.3,401.1 253.9,416 208,416 93.1,416 0,322.9 0,208 0,93.1 93.1,0 208,0 322.9,0 416,93.1 416,208z M208,352A144,144,0,1,0,208,64A144,144,0,1,0,208,352z"
                            Foreground="{DynamicResource InnerForegroundColor}"
                            Height="14"
                            Width="14" />
                    </TextBox.InnerRightContent>
                </TextBox>
            </StackPanel>
        </Panel>
        <controls:ScrollView
            Background="Transparent"
            Classes="Flat"
            DockPanel.Dock="Bottom"
            Margin="0,0,5,5"
            Name="MainScrollViewer">
            <ItemsControl
                ItemsSource="{Binding FilteredMinecraftInstances}"
                Margin="2,0,9,0"
                VerticalAlignment="Top">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid
                            ColumnSpacing="12"
                            Columns="{Binding #MainScrollViewer.Bounds.Width, Converter={StaticResource WidthToColumnsConv}}"
                            RowSpacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="classes:MinecraftInstance">
                        <Border
                            Background="{DynamicResource TranslucentBackgroundColor}"
                            BorderBrush="{DynamicResource TranslucentBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Height="125"
                            Name="InstanceCard">
                            <!--  ToolTip.Tip="{Binding FullInfo}"  -->
                            <Border.Styles>
                                <Style Selector="Border#InstanceCard">
                                    <Style Selector="^ Button#UnfavoritedButton">
                                        <Setter Property="Opacity" Value="0" />
                                    </Style>
                                </Style>
                                <Style Selector="Border#InstanceCard:pointerover">
                                    <Style Selector="^ Button#UnfavoritedButton">
                                        <Setter Property="Opacity" Value="1" />
                                    </Style>
                                </Style>
                            </Border.Styles>
                            <DockPanel Margin="12,12,12,5">
                                <DockPanel DockPanel.Dock="Top">
                                    <Border
                                        ClipToBounds="True"
                                        CornerRadius="10"
                                        Height="40"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,8,0"
                                        Width="40">
                                        <Image
                                            Height="40"
                                            Source="{Binding Icon}"
                                            Width="40" />
                                    </Border>
                                    <TextBlock
                                        Margin="2,3,0,0"
                                        MaxLines="2"
                                        Text="{Binding InstanceName}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap" />
                                </DockPanel>
                                <StackPanel
                                    DockPanel.Dock="Bottom"
                                    Margin="0,0,0,5"
                                    Spacing="2"
                                    VerticalAlignment="Bottom">
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{DynamicResource InnerForegroundColor}"
                                        Margin="0,4,0,0"
                                        MaxLines="1"
                                        Text="{Binding FolderName}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{DynamicResource InnerForegroundColor}"
                                        MaxLines="1"
                                        Text="{Binding ShortDisplay}"
                                        TextTrimming="CharacterEllipsis" />
                                    <DockPanel>
                                        <TextBlock
                                            DockPanel.Dock="Left"
                                            FontSize="12"
                                            Foreground="{DynamicResource InnerForegroundColor}"
                                            MaxLines="1"
                                            Text="{Binding DisplayLastPlayTime}"
                                            TextTrimming="CharacterEllipsis" />
                                        <StackPanel
                                            DockPanel.Dock="Right"
                                            HorizontalAlignment="Right"
                                            Orientation="Horizontal">
                                            <Button
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="FavoritedButton_OnClick"
                                                Cursor="Hand"
                                                IsVisible="{Binding !Config.IsFavorite}"
                                                Padding="4,0,4,0"
                                                Tag="{Binding}"
                                                Theme="{StaticResource TransparentButton}"
                                                x:Name="UnfavoritedButton">
                                                <PathIcon
                                                    Data="F1 M640,640z M0,0z M320.1,32C329.1,32,337.4,37.1,341.5,45.1L415,189.3 574.9,214.7C583.8,216.1 591.2,222.4 594,231 596.8,239.6 594.5,249 588.2,255.4L473.7,369.9 499,529.8C500.4,538.7 496.7,547.7 489.4,553 482.1,558.3 472.4,559.1 464.4,555L320.1,481.6 175.8,555C167.8,559.1 158.1,558.3 150.8,553 143.5,547.7 139.8,538.8 141.2,529.8L166.4,369.9 52,255.4C45.6,249 43.4,239.6 46.2,231 49,222.4 56.3,216.1 65.3,214.7L225.2,189.3 298.8,45.1C302.9,37.1,311.2,32,320.2,32z M320.1,108.8L262.3,222C258.8,228.8,252.3,233.6,244.7,234.8L119.2,254.8 209,344.7C214.4,350.1,216.9,357.8,215.7,365.4L195.9,490.9 309.2,433.3C316,429.8,324.1,429.8,331,433.3L444.3,490.9 424.5,365.4C423.3,357.8,425.8,350.1,431.2,344.7L521,254.8 395.5,234.8C387.9,233.6,381.4,228.8,377.9,222L320.1,108.8z"
                                                    Foreground="{DynamicResource InnerForegroundColor}"
                                                    Height="14"
                                                    Width="14" />
                                                <Button.Transitions>
                                                    <Transitions>
                                                        <DoubleTransition
                                                            Duration="0:0:0.15"
                                                            Easing="SineEaseOut"
                                                            Property="Opacity" />
                                                    </Transitions>
                                                </Button.Transitions>
                                            </Button>
                                            <Button
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="FavoritedButton_OnClick"
                                                Cursor="Hand"
                                                IsVisible="{Binding Config.IsFavorite}"
                                                Padding="4,0,4,0"
                                                Tag="{Binding}"
                                                Theme="{StaticResource TransparentButton}"
                                                x:Name="FavoritedButton">
                                                <StackPanel Orientation="Horizontal" Spacing="2">
                                                    <PathIcon
                                                        Data="F1 M640,640z M0,0z M341.5,45.1C337.4,37.1 329.1,32 320.1,32 311.1,32 302.8,37.1 298.7,45.1L225.1,189.3 65.2,214.7C56.3,216.1 48.9,222.4 46.1,231 43.3,239.6 45.6,249 51.9,255.4L166.3,369.9 141.1,529.8C139.7,538.7 143.4,547.7 150.7,553 158,558.3 167.6,559.1 175.7,555L320.1,481.6 464.4,555C472.4,559.1 482.1,558.3 489.4,553 496.7,547.7 500.4,538.8 499,529.8L473.7,369.9 588.1,255.4C594.5,249 596.7,239.6 593.9,231 591.1,222.4 583.8,216.1 574.8,214.7L415,189.3 341.5,45.1z"
                                                        Foreground="{DynamicResource InnerForegroundColor}"
                                                        Height="14"
                                                        Width="14" />
                                                    <TextBlock
                                                        FontSize="12"
                                                        Foreground="{DynamicResource InnerForegroundColor}"
                                                        MaxLines="1"
                                                        Text="已收藏"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </controls:ScrollView>
    </DockPanel>
</UserControl>