<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.SettingPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:const="clr-namespace:Portal.Const"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Margin="20" Spacing="12" MaxWidth="400">
            <TextBlock
                FontSize="18"
                FontWeight="DemiBold"
                Text="亚克力设置" />
            <Border
                IsVisible="{Binding AcrylicEnabled, Source={x:Static const:Data.ConfigEntry}}">
                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource SukiMuteText}"
                        Text="亚克力颜色" />
                    <ColorPicker
                        Color="{Binding BackgroundSolidColor, Source={x:Static const:Data.ConfigEntry}}"
                        HorizontalAlignment="Stretch" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource SukiMuteText}"
                        Text="亚克力不透明度" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Slider
                            Grid.Column="0"
                            Maximum="1.0"
                            Minimum="0.0"
                            Value="{Binding AcrylicOpacity, Source={x:Static const:Data.ConfigEntry}}" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="6,0,0,0"
                            Text="{Binding AcrylicOpacity, Source={x:Static const:Data.ConfigEntry}, StringFormat={}{0:P0}}"
                            VerticalAlignment="Center"
                            Width="40" />
                    </Grid>
                </StackPanel>
            </Border>
            <TextBlock
                FontSize="14"
                IsVisible="{Binding AcrylicEnabled, Source={x:Static const:Data.ConfigEntry}, Converter={x:Static BoolConverters.Not}}"
                Text="亚克力效果未开启，请在标题栏设置 → 主题 → 亚克力效果中开启。" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
