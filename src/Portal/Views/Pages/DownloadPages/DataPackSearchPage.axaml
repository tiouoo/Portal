<UserControl
    d:DesignHeight="450" d:DesignWidth="800" mc:Ignorable="d"
    x:Class="Portal.Views.Pages.DownloadPages.DataPackSearchPage" x:DataType="local:DataPackSearchPageViewModel"
    xmlns="https://github.com/avaloniaui" xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
    xmlns:controls="clr-namespace:SmoothScroll.Avalonia.Controls;assembly=SmoothScroll.Avalonia.Controls" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Portal.Views.Pages.DownloadPages" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="12,0,12,12"><StackPanel DockPanel.Dock="Top" Spacing="8"><DockPanel><StackPanel DockPanel.Dock="Left" Orientation="Horizontal"><TextBlock FontSize="24" Text="数据包搜索" /><TextBlock Foreground="{DynamicResource InnerForegroundColor}" Margin="5,10,0,0" Text="{Binding StatusText}" /></StackPanel><tio:Pagination Command="{Binding GoToPageCommand}" CommandParameter="{Binding CurrentPage}" CurrentPage="{Binding CurrentPage}" DockPanel.Dock="Right" HorizontalAlignment="Right" IsVisible="{Binding HasResults}" PageSize="40" TotalCount="{Binding TotalCount}" /></DockPanel><DockPanel><Button Command="{Binding SearchCommand}" Content="搜索" DockPanel.Dock="Right" /><TextBox KeyDown="SearchBox_OnKeyDown" Margin="0,0,10,0" PlaceholderText="搜索数据包" Text="{Binding SearchText}" /></DockPanel><UniformGrid ColumnSpacing="10" Height="32" Rows="1"><ComboBox ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox><ComboBox IsEditable="True" ItemsSource="{Binding MinecraftVersions}" PlaceholderText="游戏版本" Text="{Binding GameVersion, Mode=TwoWay}" /><ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></UniformGrid><Button Command="{Binding RetryCommand}" Content="重试" HorizontalAlignment="Left" IsVisible="{Binding HasError}" /></StackPanel><controls:ScrollView Classes="Flat" Margin="0,10,0,0"><ItemsRepeater ItemsSource="{Binding Results}" Margin="0,0,10,0"><ItemsRepeater.Layout><UniformGridLayout ItemsStretch="Fill" MinColumnSpacing="16" MinItemHeight="117" MinItemWidth="300" MinRowSpacing="16" /></ItemsRepeater.Layout><ItemsRepeater.ItemTemplate><DataTemplate x:DataType="local:JavaResourceSearchResultItem"><Border Background="{DynamicResource TranslucentBackgroundColor}" BorderBrush="{DynamicResource TranslucentBorderBrush}" BorderThickness="1" CornerRadius="10" Cursor="Hand" Padding="10" PointerPressed="Result_OnPointerPressed"><DockPanel><DockPanel DockPanel.Dock="Top"><Border Background="{DynamicResource TranslucentBorderBrush}" CornerRadius="12" DockPanel.Dock="Left" Height="56" Width="56"><asyncImageLoader:AdvancedImage CornerRadius="12" Loader="{Binding ImageLoader}" Source="{Binding IconUrl}" /></Border><StackPanel Margin="10,1,0,0" VerticalAlignment="Center"><TextBlock FontSize="16" FontWeight="SemiBold" MaxLines="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" /><TextBlock FontSize="13" Foreground="{DynamicResource InnerForegroundColor}" Text="{Binding Metadata}" /></StackPanel></DockPanel><TextBlock FontSize="13" Foreground="{DynamicResource InnerForegroundColor}" Margin="3,5,3,0" MaxLines="2" Text="{Binding Summary}" TextTrimming="CharacterEllipsis" TextWrapping="WrapWithOverflow" /></DockPanel></Border></DataTemplate></ItemsRepeater.ItemTemplate></ItemsRepeater></controls:ScrollView></DockPanel>
</UserControl>
