<UserControl
    d:DesignHeight="300"
    d:DesignWidth="480"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.DownloadPages.JavaResourceInstallDialog"
    x:DataType="local:JavaResourceInstallDialogViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Portal.Views.Pages.DownloadPages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24" RowDefinitions="Auto,Auto,Auto,Auto" Width="480">
        <StackPanel Spacing="4">
            <TextBlock>
                <Run FontSize="16" Text="安装" />
                <Run FontSize="16" Text="{Binding Definition.DisplayName}" />
                <Run FontSize="16" Text="：" />
                <Run FontSize="16" Text="{Binding File.DisplayName}" />
            </TextBlock>
            <TextBlock Foreground="{DynamicResource InnerForegroundColor}" Text="{Binding Metadata}" TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <StackPanel Grid.Row="1" Margin="0,18,0,0" Spacing="6">
            <DockPanel LastChildFill="False">
                <CheckBox Content="显示所有实例" DockPanel.Dock="Right" IsChecked="{Binding ShowAllInstances}" />
                <TextBlock Text="安装目标实例" VerticalAlignment="Center" />
            </DockPanel>
            <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Instances}" Padding="10,6,6,4" SelectedItem="{Binding SelectedInstance}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="local:JavaResourceInstallInstanceItem">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" />
                            <TextBlock FontSize="11" Foreground="{DynamicResource InnerForegroundColor}" Text="{Binding Description}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Foreground="{DynamicResource InnerForegroundColor}" IsVisible="{Binding HasNoInstances}" Text="没有兼容的 Java 版实例" />
        </StackPanel>
        <StackPanel Grid.Row="2" IsVisible="{Binding IsDataPack}" Margin="0,18,0,0" Spacing="6">
            <TextBlock Text="安装目标存档" />
            <ComboBox HorizontalAlignment="Stretch" IsEnabled="{Binding !IsLoadingWorlds}" ItemsSource="{Binding Worlds}" Padding="10,6,6,4" SelectedItem="{Binding SelectedWorld}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="local:JavaResourceInstallWorldItem">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" />
                            <TextBlock FontSize="11" Foreground="{DynamicResource InnerForegroundColor}" Text="{Binding Description}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Foreground="{DynamicResource InnerForegroundColor}" IsVisible="{Binding IsLoadingWorlds}" Text="正在读取存档..." />
            <TextBlock Foreground="{DynamicResource InnerForegroundColor}" IsVisible="{Binding HasNoWorlds}" Text="该实例没有可安装数据包的存档" />
        </StackPanel>
        <DockPanel Grid.Row="3" LastChildFill="False" Margin="0,22,0,0">
            <Button Click="SaveAs_Click" Content="另存为" DockPanel.Dock="Left" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                <Button Click="Cancel_Click" Content="取消" />
                <Button Click="Install_Click" Content="确定" IsEnabled="{Binding CanInstall}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
