<UserControl
    x:Class="Portal.Views.Pages.InstancePages.WorldSaveScoreboard"
    x:DataType="local:WorldSaveDetailsViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:controls="clr-namespace:SmoothScroll.Avalonia.Controls;assembly=SmoothScroll.Avalonia.Controls"
    xmlns:local="clr-namespace:Portal.Views.Pages.InstancePages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Spacing="8">
            <TextBlock
                FontSize="22"
                FontWeight="SemiBold"
                Text="积分榜管理" />
            <TextBlock
                Foreground="{DynamicResource InnerForegroundColor}"
                Text="管理 scoreboard.dat 中的目标及其玩家分数。"
                TextWrapping="Wrap" />
        </StackPanel>
        <controls:ScrollView Grid.Row="1" Margin="0,14,0,0">
            <StackPanel Margin="0,7,0,0" Spacing="12">
                <TextBlock IsVisible="{Binding IsLoading}" Text="正在读取积分榜..." />
                <TextBlock IsVisible="{Binding !HasScoreboard}" Text="此世界未找到积分榜数据文件。" />
                <StackPanel IsVisible="{Binding HasScoreboard}" Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="积分榜目标" />
                        <Button
                            Command="{Binding AddObjectiveCommand}"
                            Content="新增目标"
                            Grid.Column="1" />
                    </Grid>
                    <ItemsRepeater ItemsSource="{Binding ScoreboardObjectives}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="local:WorldScoreboardObjectiveSetting">
                                <Grid
                                    ColumnDefinitions="120,*,*,Auto"
                                    ColumnSpacing="8"
                                    Margin="0,0,0,4">
                                    <TextBox
                                        PlaceholderText="名称"
                                        Text="{Binding Name}"
                                        TextWrapping="NoWrap" />
                                    <TextBox
                                        Grid.Column="1"
                                        PlaceholderText="统计条件"
                                        Text="{Binding CriteriaName}"
                                        TextWrapping="NoWrap" />
                                    <TextBox
                                        Grid.Column="2"
                                        PlaceholderText="显示名称"
                                        Text="{Binding DisplayName}"
                                        TextWrapping="NoWrap" />
                                    <Button
                                        Click="RemoveObjective_OnClick"
                                        Content="删除"
                                        Grid.Column="3" />
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="玩家分数" />
                        <Button
                            Command="{Binding AddScoreCommand}"
                            Content="新增分数"
                            Grid.Column="1" />
                    </Grid>
                    <ItemsRepeater ItemsSource="{Binding ScoreboardScores}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="local:WorldScoreboardScoreSetting">
                                <Grid
                                    ColumnDefinitions="110,110,*,80,Auto,Auto"
                                    ColumnSpacing="8"
                                    Margin="0,0,0,4">
                                    <TextBox
                                        PlaceholderText="目标"
                                        Text="{Binding Objective}"
                                        TextWrapping="NoWrap" />
                                    <TextBox
                                        Grid.Column="1"
                                        PlaceholderText="玩家名称"
                                        Text="{Binding Name}"
                                        TextWrapping="NoWrap" />
                                    <TextBox
                                        Grid.Column="2"
                                        PlaceholderText="显示名称"
                                        Text="{Binding DisplayName}"
                                        TextWrapping="NoWrap" />
                                    <TextBox
                                        Grid.Column="3"
                                        PlaceholderText="分数"
                                        Text="{Binding Score}"
                                        TextWrapping="NoWrap" />
                                    <ToggleSwitch
                                        Grid.Column="4"
                                        IsChecked="{Binding Locked}"
                                        OffContent="未锁定"
                                        OnContent="锁定" />
                                    <Button
                                        Click="RemoveScore_OnClick"
                                        Content="删除"
                                        Grid.Column="5" />
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>
        </controls:ScrollView>
        <Button
            Command="{Binding SaveScoreboardCommand}"
            Content="保存"
            Grid.Row="2"
            HorizontalAlignment="Right"
            IsEnabled="{Binding HasScoreboard}"
            Margin="0,12,0,0" />
    </Grid>
</UserControl>
