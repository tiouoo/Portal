<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.InstancePages.Properties"
    x:DataType="instancePages:Properties"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:instancePages="clr-namespace:Portal.Views.Pages.InstancePages"
    xmlns:java="clr-namespace:Portal.Core.Minecraft.Instance.Java;assembly=Portal.Core"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="10" Spacing="5">
        <TextBlock FontSize="24" Text="配置管理" />
        <Border
            Background="Transparent"
            BorderBrush="{DynamicResource TranslucentBorderBrush}"
            BorderThickness="0"
            CornerRadius="12"
            Padding="12">
            <StackPanel Spacing="15">
                <StackPanel Spacing="5">
                    <Label
                        Content="备注"
                        FontSize="13"
                        Foreground="{DynamicResource InnerForegroundColor}" />
                    <TextBox PlaceholderText="请输入备注" Text="{Binding Instance.Config.Note}" />
                </StackPanel>
                <StackPanel IsVisible="{Binding Instance.IsBedrock}" Spacing="12">
                    <StackPanel Spacing="5">
                        <Label
                            Content="独立数据"
                            FontSize="13"
                            Foreground="{DynamicResource InnerForegroundColor}" />
                        <ToggleSwitch IsChecked="{Binding Instance.EnableIndependentBedrockVersion}" />
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <Label
                            Content="启动器间共享数据"
                            FontSize="13"
                            Foreground="{DynamicResource InnerForegroundColor}" />
                        <ToggleSwitch IsChecked="{Binding Instance.EnableLauncherSharedBedrockData}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel IsVisible="{Binding Instance.IsJava}" Spacing="12">
                    <TextBlock FontSize="18" Text="Java 版配置" />
                    <TextBlock
                        FontSize="13"
                        Foreground="{DynamicResource InnerForegroundColor}"
                        Text="游玩时长、最近启动和会话次数会自动记录在此实例中。" />
                    <StackPanel Spacing="5">
                        <Label
                            Content="独立实例"
                            FontSize="13"
                            Foreground="{DynamicResource InnerForegroundColor}" />
                        <ToggleSwitch IsChecked="{Binding Instance.JavaConfig.EnableIndependentInstance}" />
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <Label
                            Content="使用特定Java"
                            FontSize="13"
                            Foreground="{DynamicResource InnerForegroundColor}" />
                        <ToggleSwitch IsChecked="{Binding Instance.JavaConfig.EnableSpecificJava}" />
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <StackPanel IsVisible="{Binding Instance.JavaConfig.EnableSpecificJava}" Spacing="5">
                            <Label
                                Content="选择Java"
                                FontSize="13"
                                Foreground="{DynamicResource InnerForegroundColor}" />
                            <ComboBox
                                Height="46"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding Data.ConfigEntry.JavaRuntimes}"
                                SelectedItem="{Binding Instance.JavaConfig.SpecificJavaEntry}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="java:JavaRuntimeEntry">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{DynamicResource InnerForegroundColor}"
                                                Text="{Binding JavaPath}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <Label
                            Content="覆盖全局最大内存"
                            FontSize="13"
                            Foreground="{DynamicResource InnerForegroundColor}" />
                        <ToggleSwitch IsChecked="{Binding Instance.JavaConfig.EnableOverrideMaxMemory}" />
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <StackPanel IsVisible="{Binding Instance.JavaConfig.EnableOverrideMaxMemory}" Spacing="5">
                            <Label
                                Content="最大内存"
                                FontSize="13"
                                Foreground="{DynamicResource InnerForegroundColor}" />
                            <Grid ColumnDefinitions="*,Auto">
                                <Slider
                                    Grid.Column="0"
                                    IsSnapToTickEnabled="True"
                                    Maximum="65536"
                                    Minimum="512"
                                    TickFrequency="256"
                                    Value="{Binding Instance.JavaConfig.MinecraftMaxMemory}" />
                                <Border
                                    Grid.Column="1"
                                    Margin="15,0,0,0"
                                    Width="75">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        Text="{Binding Instance.JavaConfig.MinecraftMaxMemory, StringFormat={}{0:0} MB}"
                                        VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
