<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.InstancePages.Properties"
    x:DataType="instancePages:Properties"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:instancePages="clr-namespace:Portal.Views.Pages.InstancePages"
    xmlns:java="clr-namespace:Portal.Core.Minecraft.Instance.Java;assembly=Portal.Core"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel
        Margin="10"
        MaxWidth="1100"
        Spacing="5">
        <TextBlock FontSize="24" Text="实例设置" />
        <Border
            Background="Transparent"
            BorderBrush="{DynamicResource TranslucentBorderBrush}"
            BorderThickness="0"
            CornerRadius="12"
            Padding="12">
            <StackPanel Spacing="15">
                <StackPanel Spacing="5">
                    <Label
                        Content="备注"
                        FontSize="13"
                        Foreground="{DynamicResource InnerForegroundColor}" />
                    <TextBox PlaceholderText="请输入备注" Text="{Binding Instance.Config.Note}" />
                </StackPanel>
                <StackPanel Spacing="5">
                    <Label
                        Content="独立实例"
                        FontSize="13"
                        Foreground="{DynamicResource InnerForegroundColor}" />
                    <ToggleSwitch IsChecked="{Binding Instance.Config.EnableIndependentInstance}" />
                </StackPanel>
                <StackPanel Spacing="5">
                    <Label
                        Content="使用特定Java"
                        FontSize="13"
                        Foreground="{DynamicResource InnerForegroundColor}" />
                    <ToggleSwitch IsChecked="{Binding Instance.Config.EnableSpecificJava}" />
                </StackPanel>
                <StackPanel IsVisible="{Binding Instance.Config.EnableSpecificJava}" Spacing="5">
                    <Label
                        Content="选择Java"
                        FontSize="13"
                        Foreground="{DynamicResource InnerForegroundColor}" />
                    <ComboBox
                        Height="46"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{Binding Data.ConfigEntry.JavaRuntimes}"
                        SelectedItem="{Binding Instance.Config.SpecificJavaEntry}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="java:JavaRuntimeEntry">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding DisplayName}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{DynamicResource InnerForegroundColor}"
                                        Text="{Binding JavaPath}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Spacing="5">
                    <Label
                        Content="覆盖全局最大内存"
                        FontSize="13"
                        Foreground="{DynamicResource InnerForegroundColor}" />
                    <ToggleSwitch IsChecked="{Binding Instance.Config.EnableOverrideMaxMemory}" />
                </StackPanel>
                <StackPanel IsVisible="{Binding Instance.Config.EnableOverrideMaxMemory}" Spacing="5">
                    <Label
                        Content="最大内存"
                        FontSize="13"
                        Foreground="{DynamicResource InnerForegroundColor}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Slider
                            Grid.Column="0"
                            IsSnapToTickEnabled="True"
                            Maximum="65536"
                            Minimum="512"
                            TickFrequency="256"
                            Value="{Binding Instance.Config.MinecraftMaxMemory}" />
                        <Border
                            Grid.Column="1"
                            Margin="15,0,0,0"
                            Width="75">
                            <TextBlock
                                HorizontalAlignment="Center"
                                Text="{Binding Instance.Config.MinecraftMaxMemory, StringFormat={}{0:0} MB}"
                                VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
