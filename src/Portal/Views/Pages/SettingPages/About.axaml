<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.SettingPages.About"
    x:DataType="settingPages:AboutViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:converter="clr-namespace:Portal.Module.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settingPages="clr-namespace:Portal.Views.Pages.SettingPages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <converter:UpdateChannelToIndexConverter x:Key="UpdateChannelToIndexConverter" />
    </UserControl.Resources>
    <StackPanel Spacing="15">
        <TextBlock FontSize="26" Text="关于" />
        <Border
            Background="{DynamicResource TranslucentBackgroundColor}"
            BorderBrush="{DynamicResource TranslucentBorderBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource TioCornerRadius}"
            Padding="10">
            <StackPanel>
                <Panel>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                FontSize="15"
                                Margin="5,0,0,0"
                                Text="Portal" />
                            <Border
                                CornerRadius="10"
                                HorizontalAlignment="Left"
                                IsVisible="{Binding Data.UiProperty.IsLatestVersion}"
                                Margin="10,0,0,0"
                                Padding="6,3,6,1"
                                VerticalAlignment="Top">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#17be74"
                                    Text="最新版" />
                                <Border.Background>
                                    <SolidColorBrush Color="#18e086" Opacity="0.3" />
                                </Border.Background>
                            </Border>
                        </StackPanel>
                        <SelectableTextBlock
                            FontSize="17"
                            Margin="5,2,0,2"
                            Text="{Binding Data.Version.VersionTitle}" />
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock
                                FontSize="13"
                                Foreground="{DynamicResource InnerForegroundColor}"
                                Margin="5,0,0,0"
                                MaxLines="1">
                                <Run Text="{Binding Info}" />
                            </TextBlock>
                            <TextBlock
                                FontSize="13"
                                Foreground="{DynamicResource InnerForegroundColor}"
                                MaxLines="1"
                                Text="|" />
                            <TextBlock
                                FontSize="13"
                                Foreground="{DynamicResource InnerForegroundColor}"
                                Margin="0,1,0,0"
                                MaxLines="1"
                                Text="{Binding Data.Version.BuildTime, StringFormat='{}{0:yyyy-MM-dd HH:MM:ss}'}" />
                        </StackPanel>
                    </StackPanel>
                    <HyperlinkButton
                        Click="Button_OnClick"
                        Content="检查更新"
                        FontSize="12"
                        HorizontalAlignment="Right"
                        Margin="0,2,5,0"
                        Name="HyperlinkButton"
                        Theme="{StaticResource TransparentHyperlinkButton}"
                        VerticalAlignment="Top" />
                </Panel>
                <StackPanel IsVisible="{Binding Data.UiProperty.FoundNewVersion}">
                    <Separator Background="{DynamicResource TranslucentBorderBrush}" Margin="0,8" />
                    <Panel>
                        <TextBlock
                            FontSize="13"
                            Margin="5,0,0,0"
                            Text="发现新版本" />
                        <HyperlinkButton
                            Click="UpdateHyperlinkButton_OnClickButton_OnClick"
                            Content="下载新版本"
                            FontSize="12"
                            HorizontalAlignment="Right"
                            Margin="0,2,5,0"
                            Name="UpdateHyperlinkButton"
                            Theme="{StaticResource TransparentHyperlinkButton}"
                            VerticalAlignment="Top" />
                    </Panel>
                    <SelectableTextBlock
                        FontSize="17"
                        Margin="5,2,0,2"
                        Text="{Binding Data.UiProperty.NewVersion}" />
                </StackPanel>
            </StackPanel>
        </Border>
        <StackPanel Spacing="5">
            <Label
                Content="自动检查更新"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}" />
            <ToggleSwitch HorizontalAlignment="Stretch" IsChecked="{Binding Data.ConfigEntry.EnableCheckAutoUpdate}" />
        </StackPanel>
        <StackPanel Spacing="5">
            <Label
                Content="更新源"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}" />
            <ComboBox HorizontalAlignment="Stretch" SelectedIndex="0">
                <ComboBoxItem Content="Github" />
            </ComboBox>
            <TextBlock
                FontSize="11"
                Foreground="{DynamicResource InnerForegroundColor}"
                Text=" *前往 设置-代理 开启GitHub代理可加快更新速度" />
        </StackPanel>
        <StackPanel Spacing="5">
            <Label
                Content="更新通道"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}" />
            <ComboBox
                HorizontalAlignment="Stretch"
                Name="UpdateChannel"
                SelectedIndex="{Binding Data.UiProperty.OverrideUpdateChannel, Converter={StaticResource UpdateChannelToIndexConverter}, Mode=TwoWay}"
                SelectionChanged="UpdateChannel_OnSelectionChanged">
                <ComboBoxItem Content="每日构建版本" />
                <ComboBoxItem Content="提交构建版本" />
            </ComboBox>
        </StackPanel>
        <Separator Background="{DynamicResource TranslucentBorderBrush}" />
        <StackPanel Spacing="5">
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="Source Code:" />
                <HyperlinkButton Content="tiouoo/Portal" Theme="{StaticResource UnderlineHyperlinkButton}" />
                <TextBlock Text=" License:" />
                <HyperlinkButton Content="GPL v3.0" Theme="{StaticResource UnderlineHyperlinkButton}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="Frontend Framework:" />
                <HyperlinkButton Content="Avalonia" Theme="{StaticResource UnderlineHyperlinkButton}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="Icon Library:" />
                <HyperlinkButton Content="Font Awesome" Theme="{StaticResource UnderlineHyperlinkButton}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="Control Library:" />
                <HyperlinkButton Content="TioUi.Avalonia" Theme="{StaticResource UnderlineHyperlinkButton}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="Minecraft Launch Library:" />
                <HyperlinkButton Content="MinecraftLaunch" Theme="{StaticResource UnderlineHyperlinkButton}" />
                <HyperlinkButton Content="BedrockLauncher.Core" Theme="{StaticResource UnderlineHyperlinkButton}" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>