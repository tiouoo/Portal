<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.SettingPages.Notification"
    x:DataType="settingPages:Notification"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settingPages="clr-namespace:Portal.Views.Pages.SettingPages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="15">
        <TextBlock FontSize="26" Text="通知与可选项" />
        <StackPanel Spacing="5">
            <Label
                Content="通知方式"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}" />
            <ComboBox
                HorizontalAlignment="Stretch"
                SelectedIndex="{Binding Data.ConfigEntry.NoticeWay}"
                SelectionChanged="SelectingItemsControl_OnSelectionChanged">
                <ComboBoxItem Content="气泡" />
                <ComboBoxItem Content="卡片" />
            </ComboBox>
        </StackPanel>
        <StackPanel Spacing="15">
            <Label
                Content="通知权限"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}" />
            <StackPanel Spacing="10">
                <DockPanel>
                    <TextBlock
                        DockPanel.Dock="Left"
                        FontSize="14"
                        HorizontalAlignment="Left"
                        Text="显示选中账户" />
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        IsChecked="{Binding Data.ConfigEntry.ShowUsingAccountTip}" />
                </DockPanel>
                <DockPanel>
                    <TextBlock
                        DockPanel.Dock="Left"
                        FontSize="14"
                        HorizontalAlignment="Left"
                        Text="文件拖入提示" />
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        IsChecked="{Binding Data.ConfigEntry.ShowDragDropTip}" />
                </DockPanel>
                <DockPanel>
                    <TextBlock
                        DockPanel.Dock="Left"
                        FontSize="14"
                        HorizontalAlignment="Left"
                        Text="更新提示" />
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        IsChecked="{Binding Data.ConfigEntry.ShowUpdateTip}" />
                </DockPanel>
            </StackPanel>
        </StackPanel>
        <StackPanel Spacing="15">
            <Label
                Content="可选项"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}" />
            <StackPanel Spacing="10">
                <DockPanel>
                    <TextBlock
                        DockPanel.Dock="Left"
                        FontSize="14"
                        HorizontalAlignment="Left"
                        Text="在新标签页中显示Minecraft新闻" />
                    <ToggleSwitch
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        IsChecked="{Binding Data.ConfigEntry.ShowMinecraftNews}" />
                </DockPanel>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>