<UserControl
    Name="Root"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.SettingPages.Java"
    x:DataType="settingPages:Java"
    xmlns="https://github.com/avaloniaui"
    xmlns:classes="clr-namespace:Portal.Core.Minecraft.Instance.Java;assembly=Portal.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settingPages="clr-namespace:Portal.Views.Pages.SettingPages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="15">
        <TextBlock FontSize="26" Text="Java 虚拟机与内存" />
        <StackPanel Spacing="5">
            <TextBlock FontSize="14" Text="自动选择适合游戏版本的 Java" />
            <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding Data.ConfigEntry.EnableAutoSelectJava}" />
        </StackPanel>
        <StackPanel Spacing="5">
            <Label
                Content="默认 Java"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}" />
            <ComboBox
                HorizontalAlignment="Stretch"
                ItemsSource="{Binding Data.ConfigEntry.JavaRuntimes}"
                SelectedItem="{Binding Data.ConfigEntry.DefaultJavaRuntime}">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="classes:JavaRuntimeEntry">
                        <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
        <DockPanel Margin="0,4,0,0">
            <Label
                Content="Java 管理"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}"
                Margin="5,0,0,0" />
            <StackPanel
                DockPanel.Dock="Right"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="10">
                <HyperlinkButton
                    Click="AutoScan_Click"
                    Content="自动扫描"
                    FontSize="13"
                    Theme="{StaticResource TransparentHyperlinkButton}" />
                <HyperlinkButton
                    Click="AddJava_Click"
                    Content="手动添加"
                    FontSize="13"
                    Theme="{StaticResource TransparentHyperlinkButton}" />
            </StackPanel>
        </DockPanel>
        <ListBox ItemsSource="{Binding Data.ConfigEntry.JavaRuntimes}" SelectedItem="{Binding Data.ConfigEntry.DefaultJavaRuntime}">
            <ListBox.Styles>
                <Style Selector="ListBoxItem Button.delete-btn">
                    <Setter Property="Opacity" Value="0" />
                </Style>
                <Style Selector="ListBoxItem:pointerover Button.delete-btn">
                    <Setter Property="Opacity" Value="1" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="classes:JavaRuntimeEntry">
                    <Grid ColumnDefinitions="*,Auto" Margin="3,6">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding DisplayName}" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource InnerForegroundColor}"
                                Text="{Binding JavaPath}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button
                            Classes="delete-btn"
                            Click="RemoveJava_Click"
                            Grid.Column="1"
                            Tag="{Binding}"
                            Theme="{StaticResource TransparentButton}"
                            VerticalAlignment="Center">
                            <PathIcon
                                Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                Height="16"
                                Width="16" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</UserControl>
