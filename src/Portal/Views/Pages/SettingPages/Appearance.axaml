<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.SettingPages.Appearance"
    xmlns="https://github.com/avaloniaui"
    xmlns:const="clr-namespace:Portal.Const"
    xmlns:converter="clr-namespace:Portal.Module.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <converter:BackgroundModeCompareConverter x:Key="BackgroundModeCompareConverter" />
    </UserControl.Resources>
    <StackPanel Spacing="15">
        <TextBlock FontSize="26" Text="显示与外观" />
        <StackPanel Spacing="5">
            <Label
                Content="主题样式"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}" />
            <TabStrip Theme="{DynamicResource BorderTabStrip}">
                <TabStripItem Background="#18ffffff">
                    <StackPanel Orientation="Horizontal">
                        <PathIcon
                            Data="F1 M640,640z M0,0z M208.3,256C251.4,256 288.8,280.4 307.5,316.1 322.2,298.9 343.9,288 368.3,288 412.5,288 448.3,323.8 448.3,368 448.3,373.5 447.7,378.9 446.7,384 447.2,384 447.8,384 448.3,384 501.3,384 544.3,427 544.3,480 544.3,533 501.3,576 448.3,576L128.3,576C75.3,576 32.3,533 32.3,480 32.3,437.5 60,401.5 98.3,388.8 97,382 96.3,375.1 96.3,368 96.3,306.1 146.4,256 208.3,256z M400.3,32.2C405.6,32.2,410.6,34.9,413.6,39.3L460.9,109.7 544.2,93.4C549.4,92.4 554.8,94.1 558.5,97.8 562.3,101.6 563.9,107 562.9,112.2L546.6,195.5 617,242.8C621.4,245.8 624.1,250.8 624.1,256.1 624.1,261.4 621.5,266.4 617.1,269.3L546.7,316.6 561.2,390.8C544,369.1 520.8,352.4 494,343.5 491.5,330.8 487.1,318.9 481.2,307.8 490.8,292.9 496.4,275.1 496.4,256.1 496.4,203.1 453.4,160.1 400.4,160.1 352.5,160.1 312.8,195.2 305.6,241 284.7,225 259.7,214 232.5,209.9L254,195.4 237.7,112.2 237.4,110.2C237.1,105.6 238.7,101.1 242,97.8 245.8,94 251.2,92.4 256.4,93.4L339.7,109.7 387,39.3 388.2,37.7C391.2,34.2,395.6,32.2,400.3,32.2z M400.3,208C426.8,208 448.3,229.5 448.3,256 448.3,259.8 447.8,263.6 446.9,267.1 425.2,250.2 398,240 368.3,240 363.7,240 359.2,240.2 354.8,240.7 361.2,221.7 379.1,208 400.3,208z"
                            Height="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="16" />
                        <Rectangle
                            Fill="{DynamicResource PopupBorderBrush}"
                            Margin="5,0"
                            VerticalAlignment="Stretch"
                            Width="1" />
                        <TextBlock Text="系统" />
                    </StackPanel>
                </TabStripItem>
                <TabStripItem Background="#18ffffff">
                    <StackPanel Orientation="Horizontal">
                        <PathIcon
                            Data="F1 M640,640z M0,0z M320,32C328,32,335.4,36,339.9,42.6L398.7,130 502.1,109.8C509.9,108.3 518,110.7 523.7,116.4 529.4,122.1 531.8,130.2 530.3,138L510,241.3 597.4,300.1C604,304.5 608,312 608,320 608,328 604,335.4 597.4,339.9L510,398.7 530.2,502C531.7,509.8 529.3,517.9 523.6,523.6 517.9,529.3 509.8,531.7 502,530.2L398.7,510 339.9,597.4C335.4,604 328,608 320,608 312,608 304.6,604 300.1,597.4L241.3,510 137.9,530.2C130.1,531.7 122,529.3 116.3,523.6 110.6,517.9 108.2,509.8 109.7,502L130,398.7 42.6,339.9C36,335.4 32,328 32,320 32,312 36,304.6 42.6,300.1L130,241.3 109.8,137.9C108.3,130.1 110.7,122 116.4,116.3 122.1,110.6 130.2,108.2 138,109.7L241.3,129.9 300.1,42.5 301.9,40.2C306.4,35,313,32,320,32z M272.2,170C266.8,178,257.2,182,247.7,180.2L163.7,163.8 180.1,247.8C181.9,257.3,177.9,266.9,169.9,272.3L99,320 170,367.8C178,373.2,182,382.8,180.2,392.3L163.8,476.3 247.8,459.9 251.3,459.5C259.6,459.1,267.6,463.1,272.3,470.1L320.1,541.1 367.9,470.1 370.1,467.3C375.7,461.2,384.1,458.3,392.4,460L476.4,476.4 460,392.4C458.2,382.9,462.2,373.3,470.2,367.9L541.2,320.1 470.2,272.3C462.2,266.9,458.2,257.3,460,247.8L476.4,163.8 392.4,180.2C382.9,182,373.3,178,367.9,170L320.1,99 272.3,170z M320,440C253.7,440 200,386.3 200,320 200,253.7 253.7,200 320,200 386.3,200 440,253.7 440,320 440,386.3 386.3,440 320,440z M320,248C280.2,248 248,280.2 248,320 248,359.8 280.2,392 320,392 359.8,392 392,359.8 392,320 392,280.2 359.8,248 320,248z"
                            Height="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="16" />
                        <Rectangle
                            Fill="{DynamicResource PopupBorderBrush}"
                            Margin="5,0"
                            VerticalAlignment="Stretch"
                            Width="1" />
                        <TextBlock Text="浅色" />
                    </StackPanel>
                </TabStripItem>
                <TabStripItem Background="#18ffffff">
                    <StackPanel Orientation="Horizontal">
                        <PathIcon
                            Data="F1 M640,640z M0,0z M320,64C178.6,64 64,178.6 64,320 64,461.4 178.6,576 320,576 388.8,576 451.3,548.8 497.3,504.6 504.6,497.6 506.7,486.7 502.6,477.5 498.5,468.3 488.9,462.6 478.8,463.4 473.9,463.8 469,464 464,464 362.4,464 280,381.6 280,280 280,207.9 321.5,145.4 382.1,115.2 391.2,110.7 396.4,100.9 395.2,90.8 394,80.7 386.6,72.5 376.7,70.3 358.4,66.2 339.4,64 320,64z"
                            Height="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="16" />
                        <Rectangle
                            Fill="{DynamicResource PopupBorderBrush}"
                            Margin="5,0"
                            VerticalAlignment="Stretch"
                            Width="1" />
                        <TextBlock Text="深色" />
                    </StackPanel>
                </TabStripItem>
                <TabStripItem Background="#18ffffff">
                    <StackPanel Orientation="Horizontal">
                        <PathIcon
                            Data="F1 M640,640z M0,0z M168.1,531.1L156.9,540.1C153.7,542.6 149.8,544 145.8,544 136,544 128,536 128,526.2L128,256C128,150 214,64 320,64 426,64 512,150 512,256L512,526.2C512,536 504,544 494.2,544 490.2,544 486.3,542.6 483.1,540.1L471.9,531.1C458.5,520.4,439.1,522.1,427.8,535L397.3,570C394,573.8 389.1,576 384,576 378.9,576 374.1,573.8 370.7,570L344.1,539.5C331.4,524.9,308.7,524.9,295.9,539.5L269.3,570C266,573.8 261.1,576 256,576 250.9,576 246.1,573.8 242.7,570L212.2,535C200.9,522.1,181.5,520.4,168.1,531.1z M288,256C288,238.3 273.7,224 256,224 238.3,224 224,238.3 224,256 224,273.7 238.3,288 256,288 273.7,288 288,273.7 288,256z M384,288C401.7,288 416,273.7 416,256 416,238.3 401.7,224 384,224 366.3,224 352,238.3 352,256 352,273.7 366.3,288 384,288z"
                            Height="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="16" />
                        <Rectangle
                            Fill="{DynamicResource PopupBorderBrush}"
                            Margin="5,0"
                            VerticalAlignment="Stretch"
                            Width="1" />
                        <TextBlock Text="幻影" />
                    </StackPanel>
                </TabStripItem>
            </TabStrip>
        </StackPanel>
        <StackPanel Spacing="5" Margin="0,10,0,0">
            <Label
                Content="背景风格"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}" />
            <ComboBox SelectedIndex="{Binding BackgroundMode, Source={x:Static const:Data.ConfigEntry}}" Width="200">
                <ComboBoxItem>默认主题</ComboBoxItem>
                <ComboBoxItem>图片</ComboBoxItem>
                <ComboBoxItem>纯色</ComboBoxItem>
                <ComboBoxItem>亚克力</ComboBoxItem>
            </ComboBox>
            <Border
                IsVisible="{Binding BackgroundMode, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource BackgroundModeCompareConverter}, ConverterParameter='SolidColor'}">
                <StackPanel Spacing="6" Margin="0,5,0,0">
                    <StackPanel Spacing="3">
                        <TextBlock FontSize="12" Foreground="{DynamicResource SukiMuteText}" Text="背景颜色" />
                        <ColorPicker
                            Color="{Binding BackgroundSolidColor, Source={x:Static const:Data.ConfigEntry}}"
                            HorizontalAlignment="Left" Width="280" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border
                IsVisible="{Binding BackgroundMode, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource BackgroundModeCompareConverter}, ConverterParameter='Image'}">
                <StackPanel Spacing="6" Margin="0,5,0,0">
                    <tio:PathPicker
                        FileFilter="[ImageAll]"
                        SelectedPathsText="{Binding BackgroundImagePath, Source={x:Static const:Data.ConfigEntry}}"
                        Title="选择背景图片"
                        UsePickerType="OpenFile" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource SukiMuteText}"
                        Text="{Binding BackgroundImagePath, Source={x:Static const:Data.ConfigEntry}}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <StackPanel Spacing="3">
                        <TextBlock FontSize="12" Foreground="{DynamicResource SukiMuteText}" Text="模糊程度" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Slider Grid.Column="0" Maximum="1.0" Minimum="0.0"
                                Value="{Binding ImageBlurRadius, Source={x:Static const:Data.ConfigEntry}}" />
                            <TextBlock Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Center" Width="40"
                                Text="{Binding ImageBlurRadius, Source={x:Static const:Data.ConfigEntry}, StringFormat={}{0:P0}}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border
                IsVisible="{Binding BackgroundMode, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource BackgroundModeCompareConverter}, ConverterParameter='Acrylic'}">
                <StackPanel Spacing="6" Margin="0,5,0,0">
                    <StackPanel Spacing="3">
                        <TextBlock FontSize="12" Foreground="{DynamicResource SukiMuteText}" Text="亚克力颜色" />
                        <ColorPicker
                            Color="{Binding BackgroundSolidColor, Source={x:Static const:Data.ConfigEntry}}"
                            HorizontalAlignment="Left" Width="280" />
                    </StackPanel>
                    <StackPanel Spacing="3">
                        <TextBlock FontSize="12" Foreground="{DynamicResource SukiMuteText}" Text="不透明度" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Slider Grid.Column="0" Maximum="1.0" Minimum="0.0"
                                Value="{Binding AcrylicOpacity, Source={x:Static const:Data.ConfigEntry}}" />
                            <TextBlock Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Center" Width="40"
                                Text="{Binding AcrylicOpacity, Source={x:Static const:Data.ConfigEntry}, StringFormat={}{0:P0}}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
        <StackPanel Spacing="5" Margin="0,10,0,0">
            <Label
                Content="字体颜色"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}" />
            <StackPanel Spacing="3">
                <TextBlock FontSize="12" Foreground="{DynamicResource SukiMuteText}" Text="全局字体颜色" />
                <ColorPicker
                    Color="{Binding ForegroundColor, Source={x:Static const:Data.ConfigEntry}}"
                    HorizontalAlignment="Left" Width="280" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
