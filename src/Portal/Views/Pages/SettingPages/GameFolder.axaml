<UserControl
    Name="Root"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.SettingPages.GameFolder"
    x:DataType="settingPages:GameFolder"
    xmlns="https://github.com/avaloniaui"
    xmlns:classes="clr-namespace:Portal.Core.Minecraft.Classes;assembly=Portal.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settingPages="clr-namespace:Portal.Views.Pages.SettingPages"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="15">
        <TextBlock FontSize="26" Text="游戏文件夹" />
        <StackPanel Spacing="5">
            <Label
                Content="默认文件夹"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}" />
            <ComboBox
                HorizontalAlignment="Stretch"
                ItemsSource="{Binding Data.ConfigEntry.MinecraftFolders}"
                SelectedItem="{Binding Data.ConfigEntry.DefaultMinecraftFolder}">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="classes:MinecraftFolderEntry">
                        <TextBlock>
                            <Run Text="[" />
                            <Run Text="{Binding FolderName}" />
                            <Run Text="]" />
                            <Run Text="{Binding FolderPath}" />
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
        <StackPanel Spacing="5">
            <DockPanel Margin="0,4,0,0">
                <Label
                    Content="文件夹管理"
                    FontSize="13"
                    Foreground="{DynamicResource InnerForegroundColor}"
                    HorizontalAlignment="Left"
                    Margin="5,0,0,0" />
                <HyperlinkButton
                    Click="Button_OnClick"
                    Content="添加文件夹"
                    FontSize="13"
                    HorizontalAlignment="Right"
                    Margin="0,0,5,5"
                    Theme="{StaticResource TransparentHyperlinkButton}" />
            </DockPanel>
            <ItemsControl ItemsSource="{Binding Data.ConfigEntry.MinecraftFolders}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="10" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="classes:MinecraftFolderEntry">
                        <tio:TioExpander
                            Background="{DynamicResource TranslucentBackgroundColor}"
                            BorderBrush="{DynamicResource TranslucentBorderBrush}"
                            BorderThickness="1"
                            HeaderHeight="52"
                            IconHeight="14"
                            IconMargin="0,0,10,0"
                            IconWidth="14">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <PathIcon
                                        Data="F1 M 3.056641 18.75 C 2.646484 18.75 2.255859 18.666992 1.884766 18.500977 C 1.513672 18.334961 1.189779 18.113607 0.913086 17.836914 C 0.636393 17.560221 0.415039 17.236328 0.249023 16.865234 C 0.083008 16.494141 0 16.103516 0 15.693359 L 0 4.306641 C 0 3.896484 0.083008 3.505859 0.249023 3.134766 C 0.415039 2.763672 0.636393 2.439779 0.913086 2.163086 C 1.189779 1.886395 1.513672 1.665039 1.884766 1.499023 C 2.255859 1.333008 2.646484 1.25 3.056641 1.25 L 6.875 1.25 C 7.324219 1.25 7.709961 1.319988 8.032227 1.459961 C 8.354492 1.599936 8.645833 1.787109 8.90625 2.021484 C 9.166666 2.255859 9.407552 2.522787 9.628906 2.822266 C 9.85026 3.121746 10.078125 3.43099 10.3125 3.75 L 16.943359 3.75 C 17.353516 3.75 17.744141 3.833008 18.115234 3.999023 C 18.486328 4.165039 18.810221 4.386394 19.086914 4.663086 C 19.363605 4.939779 19.584961 5.263672 19.750977 5.634766 C 19.916992 6.005859 20 6.396484 20 6.806641 L 20 15.693359 C 20 16.103516 19.916992 16.494141 19.750977 16.865234 C 19.584961 17.236328 19.363605 17.560221 19.086914 17.836914 C 18.810221 18.113607 18.486328 18.334961 18.115234 18.500977 C 17.744141 18.666992 17.353516 18.75 16.943359 18.75 Z M 7.363281 5 C 7.539062 5.000001 7.701823 4.977215 7.851562 4.931641 C 8.001302 4.886068 8.147786 4.825847 8.291016 4.750977 C 8.434244 4.676107 8.570963 4.5931 8.701172 4.501953 C 8.83138 4.410808 8.964844 4.316406 9.101562 4.21875 C 8.951822 4.016928 8.805338 3.813477 8.662109 3.608398 C 8.51888 3.40332 8.36263 3.219402 8.193359 3.056641 C 8.024088 2.893881 7.833658 2.760418 7.62207 2.65625 C 7.410481 2.552084 7.161458 2.5 6.875 2.5 L 3.125 2.5 C 2.871094 2.5 2.630208 2.548828 2.402344 2.646484 C 2.174479 2.744141 1.974284 2.879232 1.801758 3.051758 C 1.629232 3.224285 1.494141 3.42448 1.396484 3.652344 C 1.298828 3.880209 1.25 4.121094 1.25 4.375 L 1.25 5 Z M 16.875 17.5 C 17.128906 17.5 17.369791 17.451172 17.597656 17.353516 C 17.82552 17.255859 18.025715 17.120768 18.198242 16.948242 C 18.370768 16.775717 18.505859 16.575521 18.603516 16.347656 C 18.701172 16.119791 18.75 15.878906 18.75 15.625 L 18.75 6.875 C 18.75 6.621095 18.701172 6.380209 18.603516 6.152344 C 18.505859 5.924479 18.370768 5.724284 18.198242 5.551758 C 18.025715 5.379232 17.82552 5.244142 17.597656 5.146484 C 17.369791 5.048829 17.128906 5.000001 16.875 5 L 10.185547 5 C 9.957682 5.156251 9.737955 5.309246 9.526367 5.458984 C 9.314778 5.608725 9.09668 5.742188 8.87207 5.859375 C 8.647461 5.976562 8.411458 6.070964 8.164062 6.142578 C 7.916666 6.214193 7.649739 6.25 7.363281 6.25 L 1.25 6.25 L 1.25 15.625 C 1.25 15.878906 1.298828 16.119791 1.396484 16.347656 C 1.494141 16.575521 1.629232 16.775717 1.801758 16.948242 C 1.974284 17.120768 2.174479 17.255859 2.402344 17.353516 C 2.630208 17.451172 2.871094 17.5 3.125 17.5 Z "
                                        Height="24"
                                        HorizontalAlignment="Center"
                                        Margin="8,0,4,2"
                                        VerticalAlignment="Center"
                                        Width="24" />
                                    <StackPanel Margin="10,8,0,8" Spacing="2">
                                        <TextBlock Text="{Binding FolderName}" />
                                        <Label
                                            Content="{Binding FolderPath}"
                                            FontSize="13"
                                            Foreground="{DynamicResource InnerForegroundColor}"
                                            HorizontalAlignment="Left" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander.Header>
                            <tio:TioExpander.Content>
                                <StackPanel>
                                    <Separator />
                                    <StackPanel Margin="10" Spacing="15">
                                        <StackPanel Margin="5,0,0,0" Spacing="5">
                                            <Panel>
                                                <Label
                                                    Content="文件夹名称"
                                                    FontSize="13"
                                                    Foreground="{DynamicResource InnerForegroundColor}"
                                                    HorizontalAlignment="Left" />
                                                <StackPanel
                                                    HorizontalAlignment="Right"
                                                    Margin="0,0,10,0"
                                                    Orientation="Horizontal"
                                                    Spacing="10"
                                                    VerticalAlignment="Bottom">
                                                    <HyperlinkButton
                                                        Click="Button1_OnClick"
                                                        Content="移除文件夹"
                                                        FontSize="13"
                                                        Foreground="Red"
                                                        Tag="{Binding}"
                                                        Theme="{StaticResource TransparentHyperlinkButton}" />
                                                    <HyperlinkButton
                                                        Command="{Binding OpenFolder}"
                                                        CommandParameter="{Binding ElementName=Root}"
                                                        Content="打开文件夹"
                                                        FontSize="13"
                                                        Theme="{StaticResource TransparentHyperlinkButton}" />
                                                </StackPanel>
                                            </Panel>
                                            <TextBox Text="{Binding FolderName, Mode=TwoWay}" />
                                        </StackPanel>
                                        <Panel Margin="10,0">
                                            <tio:Descriptions HorizontalAlignment="Left" LabelPosition="Top">
                                                <tio:DescriptionsItem Label="实例数量">
                                                    <TextBlock>
                                                        <Run FontSize="32" Text="{Binding InstanceCount}" />
                                                        <Run Text="个" />
                                                    </TextBlock>
                                                </tio:DescriptionsItem>
                                            </tio:Descriptions>
                                            <tio:Descriptions
                                                HorizontalAlignment="Right"
                                                LabelPosition="Top"
                                                Margin="0,0,-60,0">
                                                <tio:DescriptionsItem Label="文件夹大小">
                                                    <TextBlock>
                                                        <Run FontSize="32" Text="{Binding FolderSize}" />
                                                        <Run Text="{Binding SizeUnit}" />
                                                    </TextBlock>
                                                </tio:DescriptionsItem>
                                            </tio:Descriptions>
                                        </Panel>
                                    </StackPanel>
                                </StackPanel>
                            </tio:TioExpander.Content>
                        </tio:TioExpander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </StackPanel>
</UserControl>