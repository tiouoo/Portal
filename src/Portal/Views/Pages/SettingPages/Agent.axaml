<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.SettingPages.Agent"
    x:DataType="settingPages:Agent"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settingPages="clr-namespace:Portal.Views.Pages.SettingPages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="15">
        <TextBlock FontSize="26" Text="代理" />
        <StackPanel Spacing="5">
            <Label
                Content="自定义 UserAgent"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}" />
            <ToggleSwitch IsChecked="{Binding Data.ConfigEntry.EnableCustomUserAgent}" />
        </StackPanel>
        <StackPanel IsVisible="{Binding Data.ConfigEntry.EnableCustomUserAgent}" Spacing="5">
            <Label
                Content="UserAgent"
                FontSize="13"
                Foreground="{DynamicResource InnerForegroundColor}" />
            <TextBox Text="{Binding Data.ConfigEntry.CustomUserAgent}" />
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    FontSize="11"
                    Foreground="{DynamicResource InnerForegroundColor}"
                    Text=" *默认UserAgent: " />
                <TextBlock
                    FontSize="11"
                    Foreground="{DynamicResource InnerForegroundColor}"
                    Text="Portal/" />
                <TextBlock
                    FontSize="11"
                    Foreground="{DynamicResource InnerForegroundColor}"
                    Text="{Binding Data.Instance.Version.VersionTitle}" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>