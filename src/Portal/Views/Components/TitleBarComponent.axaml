<Grid
    Name="Root"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Components.TitleBarComponent"
    x:DataType="components:TitleBarComponent"
    xmlns="https://github.com/avaloniaui"
    xmlns:classes="clr-namespace:Portal.Core.Minecraft.Classes;assembly=Portal.Core"
    xmlns:components="clr-namespace:Portal.Views.Components"
    xmlns:const="clr-namespace:Portal.Const"
    xmlns:converter="clr-namespace:Portal.Module.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid.Styles>
        <Style Selector="Button.custom-title-bar-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Width" Value="25" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="7"
                        Height="24"
                        Name="bd"
                        Width="24">
                        <ContentControl
                            Content="{TemplateBinding Content}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Style Selector="^ /template/ Border">
                    <Setter Property="Background" Value="{DynamicResource TranslucentBackgroundColor}" />
                </Style>
                <Style Selector="^.close-button /template/ Border">
                    <Setter Property="Background">
                        <SolidColorBrush Color="Red" Opacity="{DynamicResource TranslucentBackGroundOpacity}" />
                    </Setter>
                </Style>
                <Style Selector="^.close-button /template/ Border">
                    <Style Selector="^ Path">
                        <Setter Property="Fill" Value="White" />
                    </Style>
                </Style>
            </Style>
        </Style>
    </Grid.Styles>
    <StackPanel Orientation="Horizontal">
        <StackPanel.Resources>
            <converter:StringIsNotWriteSpaceOrNullConverter x:Key="StringIsNotWriteSpaceOrNullConverter" />
            <converter:ThemeCompareConverter x:Key="ThemeCompareConverter" />
            <converter:IntCompareConverter x:Key="IntCompareConverter" />
        </StackPanel.Resources>
        <Border IsVisible="{Binding DropMsg, Converter={StaticResource StringIsNotWriteSpaceOrNullConverter}}" Margin="3,0">
            <Border
                Background="{DynamicResource TranslucentBackgroundColor}"
                BorderBrush="{DynamicResource TranslucentBorderBrush}"
                BorderThickness="1"
                CornerRadius="999"
                IsVisible="{Binding Data.ConfigEntry.ShowDragDropTip}"
                Padding="8,3,8,2"
                VerticalAlignment="Center">
                <Panel>
                    <TextBlock
                        FontSize="13"
                        Text="{Binding DropMsg}"
                        VerticalAlignment="Center" />
                </Panel>
            </Border>
        </Border>
        <Button
            Click="GoToAbout"
            IsVisible="{Binding Data.ConfigEntry.ShowUpdateTip}"
            Margin="3,0"
            Theme="{StaticResource TransparentButton}"
            VerticalAlignment="Center">
            <Border
                Background="{DynamicResource TranslucentBackgroundColor}"
                BorderBrush="{DynamicResource TranslucentBorderBrush}"
                BorderThickness="1"
                CornerRadius="999"
                IsVisible="{Binding Data.UiProperty.FoundNewVersion}"
                Padding="8,3,8,2"
                VerticalAlignment="Center">
                <Panel>
                    <TextBlock
                        FontSize="13"
                        Text="发现新版本"
                        VerticalAlignment="Center" />
                </Panel>
            </Border>
        </Button>
        <Button
            Click="AccountButton_Click"
            IsVisible="{Binding Data.ConfigEntry.ShowUsingAccountTip}"
            Margin="3,0"
            Theme="{StaticResource TransparentButton}"
            VerticalAlignment="Center"
            x:Name="AccountButton">
            <Border
                Background="{DynamicResource TranslucentBackgroundColor}"
                BorderBrush="{DynamicResource TranslucentBorderBrush}"
                BorderThickness="1"
                CornerRadius="999"
                Padding="8,3,8,2">
                <Panel>
                    <TextBlock
                        FontSize="13"
                        IsVisible="{Binding Data.ConfigEntry.MinecraftAccounts.Count, Converter={StaticResource IntCompareConverter}, ConverterParameter='== 0'}"
                        Text="无账户"
                        VerticalAlignment="Center" />
                    <TextBlock
                        FontSize="13"
                        IsVisible="{Binding Data.ConfigEntry.MinecraftAccounts.Count, Converter={StaticResource IntCompareConverter}, ConverterParameter='> 0'}"
                        Text="{Binding Data.ConfigEntry.UsingMinecraftMinecraftAccount.ShortDisplay}" />
                </Panel>
            </Border>
        </Button>
        <Button
            Classes="custom-title-bar-button"
            Click="OpenSearch"
            Margin="3,0,0,0"
            ToolTip.ShowDelay="900"
            ToolTip.Tip="搜索">
            <PathIcon
                Data="F1 M640,640z M0,0z M480,272C480,317.9,465.1,360.3,440,394.7L566.6,521.4C579.1,533.9 579.1,554.2 566.6,566.7 554.1,579.2 533.8,579.2 521.3,566.7L394.7,440C360.3,465.1 317.9,480 272,480 157.1,480 64,386.9 64,272 64,157.1 157.1,64 272,64 386.9,64 480,157.1 480,272z M272,416C351.5,416 416,351.5 416,272 416,192.5 351.5,128 272,128 192.5,128 128,192.5 128,272 128,351.5 192.5,416 272,416z"
                Height="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="16" />
        </Button>
        <Button
            Classes="custom-title-bar-button"
            Click="SettingMenuItem_OnClick"
            ToolTip.ShowDelay="900"
            ToolTip.Tip="设置">
            <PathIcon
                Data="M1024,1024z M0,0z M812.6976,195.976533L936.021333,409.6A204.8,204.8,0,0,1,936.021333,614.4L812.714667,828.023467A204.8,204.8,0,0,1,635.3408,930.423467L388.676267,930.423467A204.8,204.8,0,0,1,211.3024,828.023467L87.978667,614.4A204.8,204.8,0,0,1,87.978667,409.6L211.3024,195.976533A204.8,204.8,0,0,1,388.676267,93.576533L635.323733,93.576533A204.8,204.8,0,0,1,812.6976,195.976533z M753.578667,230.109867A136.533333,136.533333,0,0,0,635.323733,161.8432L388.676267,161.8432A136.533333,136.533333,0,0,0,270.421333,230.109867L147.114667,443.733333A136.533333,136.533333,0,0,0,147.114667,580.266667L270.4384,793.890133A136.533333,136.533333,0,0,0,388.693333,862.1568L635.3408,862.1568A136.533333,136.533333,0,0,0,753.595733,793.890133L876.885333,580.266667A136.533333,136.533333,0,0,0,876.885333,443.733333L753.5616,230.109867z M1024,1024z M0,0z M512,682.666667C606.2592,682.666667 682.666667,606.2592 682.666667,512 682.666667,417.7408 606.2592,341.333333 512,341.333333 417.7408,341.333333 341.333333,417.7408 341.333333,512 341.333333,606.2592 417.7408,682.666667 512,682.666667z M512,614.4A102.4,102.4,0,1,1,512,409.6A102.4,102.4,0,0,1,512,614.4z"
                Height="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="16" />
        </Button>
        <Separator
            Background="{DynamicResource ForegroundColor}"
            Height="18"
            IsVisible="{OnPlatform Default=True,
                                   macOS=False}"
            Margin="5,0"
            Width="1" />


        <Button IsVisible="False" Name="AccountFlyout">
            <Button.Flyout>
                <Flyout VerticalOffset="5">
                    <StackPanel>
                        <DockPanel Margin="10,0">
                            <TextBlock
                                Background="Transparent"
                                Cursor="Hand"
                                DockPanel.Dock="Left"
                                FontSize="14"
                                HorizontalAlignment="Left"
                                Margin="0,5,0,7"
                                PointerPressed="InputElement_OnPointerPressed">
                                切换账户
                            </TextBlock>
                            <Button
                                Click="AddAcountButton_OnClick"
                                DockPanel.Dock="Right"
                                HorizontalAlignment="Right"
                                Theme="{StaticResource TransparentButton}"
                                VerticalAlignment="Center">
                                <PathIcon
                                    Data="F1 M1024,1024z M0,0z M512,832A32,32,0,0,0,544,800L544,544 800,544A32,32,0,0,0,800,480L544,480 544,224A32,32,0,0,0,480,224L480,480 224,480A32,32,0,0,0,224,544L480,544 480,800A32,32,0,0,0,512,832"
                                    Height="21"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Width="21" />
                            </Button>
                        </DockPanel>

                        <ListBox
                            DockPanel.Dock="Bottom"
                            ItemsSource="{Binding Data.ConfigEntry.MinecraftAccounts}"
                            MaxHeight="208"
                            MinWidth="245"
                            SelectedItem="{Binding Data.ConfigEntry.UsingMinecraftMinecraftAccount}">

                            <ListBox.Styles>
                                <Style Selector="ListBoxItem Button.delete-btn">
                                    <Setter Property="Opacity" Value="0" />
                                </Style>
                                <Style Selector="ListBoxItem:pointerover Button.delete-btn">
                                    <Setter Property="Opacity" Value="1" />
                                </Style>
                            </ListBox.Styles>

                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="classes:MinecraftAccount">
                                    <Grid Background="Transparent" ColumnDefinitions="Auto, *, Auto">

                                        <Border
                                            ClipToBounds="True"
                                            CornerRadius="10"
                                            Grid.Column="0"
                                            Height="32"
                                            Margin="2,0,10,0"
                                            Width="32">
                                            <Image
                                                Height="32"
                                                Source="{Binding Head}"
                                                Width="32" />
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="14"
                                                Text="{Binding Name}"
                                                VerticalAlignment="Bottom" />
                                            <TextBlock
                                                FontSize="12"
                                                Text="{Binding DisplayAccountNote}"
                                                VerticalAlignment="Bottom" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="2"
                                            HorizontalAlignment="Left"
                                            Margin="5,0"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <Button
                                                Classes="delete-btn"
                                                Click="ChangeSkin_OnClick"
                                                IsVisible="{Binding IsOffline}"
                                                Tag="{Binding}"
                                                Theme="{StaticResource TransparentButton}"
                                                VerticalAlignment="Center">
                                                <PathIcon
                                                    Data="M12,4A3.5,3.5 0 0,0 8.5,7.5H10.5A1.5,1.5 0 0,1 12,6A1.5,1.5 0 0,1 13.5,7.5A1.5,1.5 0 0,1 12,9C11.45,9 11,9.45 11,10V11.75L2.4,18.2C1.63,18.78 1.39,19.83 1.97,20.6L3.21,22.43C3.79,23.2 4.84,23.44 5.61,22.86L12,17.5L18.39,22.86C19.16,23.44 20.21,23.2 20.79,22.43L22.03,20.6C22.61,19.83 22.37,18.78 21.6,18.2L13,11.75V10C13,8.9 10.7,7.5 12,4Z"
                                                    Height="14"
                                                    Width="14" />
                                                <Button.Transitions>
                                                    <Transitions>
                                                        <DoubleTransition Duration="0:0:0.1" Property="Opacity" />
                                                    </Transitions>
                                                </Button.Transitions>
                                            </Button>
                                            <Button
                                                Classes="delete-btn"
                                                Command="{Binding #Root.DeleteAccount}"
                                                CommandParameter="{Binding}"
                                                Theme="{StaticResource TransparentButton}"
                                                VerticalAlignment="Center">
                                                <PathIcon
                                                    Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                    Height="14"
                                                    Width="10" />
                                                <Button.Transitions>
                                                    <Transitions>
                                                        <DoubleTransition Duration="0:0:0.1" Property="Opacity" />
                                                    </Transitions>
                                                </Button.Transitions>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Flyout>
            </Button.Flyout>
        </Button>
    </StackPanel>
    <Rectangle
        HorizontalAlignment="Right"
        IsVisible="{Binding Data.ConfigEntry.ShowUsingAccountTip}"
        Margin="0,20,100,0"
        Name="AccountFlyoutPoint"
        VerticalAlignment="Center" />


