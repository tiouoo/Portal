<StackPanel
    Name="Root"
    Orientation="Horizontal"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Components.TitleBarComponent"
    x:DataType="components:TitleBarComponent"
    xmlns="https://github.com/avaloniaui"
    xmlns:account="clr-namespace:Portal.Core.Minecraft.Account;assembly=Portal.Core"
    xmlns:components="clr-namespace:Portal.Views.Components"
    xmlns:const="clr-namespace:Portal.Const"
    xmlns:converter="clr-namespace:Portal.Module.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel.Resources>
        <converter:ThemeCompareConverter x:Key="ThemeCompareConverter" />
        <converter:IntCompareConverter x:Key="IntCompareConverter" />
        <converter:BackgroundModeCompareConverter x:Key="BackgroundModeCompareConverter" />
    </StackPanel.Resources>
    <Button
        Click="AccountButton_Click"
        Margin="5,0"
        Theme="{StaticResource TransparentButton}"
        VerticalAlignment="Center"
        x:Name="AccountButton">
        <Border
            Background="{DynamicResource PopupBackgroundColor}"
            BorderBrush="{DynamicResource PopupBorderBrush}"
            BorderThickness="1"
            CornerRadius="999"
            Padding="8,2">
            <Panel>
                <TextBlock
                    FontSize="13"
                    IsVisible="{Binding Data.ConfigEntry.MinecraftAccounts.Count, Converter={StaticResource IntCompareConverter}, ConverterParameter='== 0'}"
                    Text="无账户" />
                <TextBlock
                    FontSize="13"
                    IsVisible="{Binding Data.ConfigEntry.MinecraftAccounts.Count, Converter={StaticResource IntCompareConverter}, ConverterParameter='> 0'}"
                    Text="{Binding Data.ConfigEntry.UsingMinecraftMinecraftAccount.ShortDisplay}" />
            </Panel>
        </Border>
    </Button>
    <Button
        Classes="custom-title-bar-button"
        ToolTip.ShowDelay="900"
        ToolTip.Tip="搜索">
        <PathIcon
            Data="F1 M640,640z M0,0z M480,272C480,317.9,465.1,360.3,440,394.7L566.6,521.4C579.1,533.9 579.1,554.2 566.6,566.7 554.1,579.2 533.8,579.2 521.3,566.7L394.7,440C360.3,465.1 317.9,480 272,480 157.1,480 64,386.9 64,272 64,157.1 157.1,64 272,64 386.9,64 480,157.1 480,272z M272,416C351.5,416 416,351.5 416,272 416,192.5 351.5,128 272,128 192.5,128 128,192.5 128,272 128,351.5 192.5,416 272,416z"
            Height="16"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="16" />
    </Button>
    <Button
        Classes="custom-title-bar-button"
        ToolTip.ShowDelay="900"
        ToolTip.Tip="设置">
        <PathIcon
            Data="M1024,1024z M0,0z M812.6976,195.976533L936.021333,409.6A204.8,204.8,0,0,1,936.021333,614.4L812.714667,828.023467A204.8,204.8,0,0,1,635.3408,930.423467L388.676267,930.423467A204.8,204.8,0,0,1,211.3024,828.023467L87.978667,614.4A204.8,204.8,0,0,1,87.978667,409.6L211.3024,195.976533A204.8,204.8,0,0,1,388.676267,93.576533L635.323733,93.576533A204.8,204.8,0,0,1,812.6976,195.976533z M753.578667,230.109867A136.533333,136.533333,0,0,0,635.323733,161.8432L388.676267,161.8432A136.533333,136.533333,0,0,0,270.421333,230.109867L147.114667,443.733333A136.533333,136.533333,0,0,0,147.114667,580.266667L270.4384,793.890133A136.533333,136.533333,0,0,0,388.693333,862.1568L635.3408,862.1568A136.533333,136.533333,0,0,0,753.595733,793.890133L876.885333,580.266667A136.533333,136.533333,0,0,0,876.885333,443.733333L753.5616,230.109867z M1024,1024z M0,0z M512,682.666667C606.2592,682.666667 682.666667,606.2592 682.666667,512 682.666667,417.7408 606.2592,341.333333 512,341.333333 417.7408,341.333333 341.333333,417.7408 341.333333,512 341.333333,606.2592 417.7408,682.666667 512,682.666667z M512,614.4A102.4,102.4,0,1,1,512,409.6A102.4,102.4,0,0,1,512,614.4z"
            Height="16"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="16" />
        <Button.Flyout>
            <Flyout VerticalOffset="5">
                <tio:GlassCard
                    BorderThickness="0"
                    CornerRadius="12"
                    IsAnimated="False"
                    MaxWidth="320"
                    Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock
                            FontSize="15"
                            FontWeight="DemiBold"
                            Margin="0,0,0,4"
                            Text="外观" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource SukiMuteText}"
                            Text="主题" />
                        <WrapPanel
                            HorizontalAlignment="Stretch"
                            Orientation="Horizontal">
                            <Button
                                Click="ThemeMenuItem_OnClick"
                                Padding="8,4"
                                Tag="System"
                                Theme="{StaticResource TransparentButton}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon
                                        Data="F1 M640,640z M0,0z M530.8,134.1C545.1,144.5,548.3,164.5,537.9,178.8L281.9,530.8C276.4,538.4 267.9,543.1 258.5,543.9 249.1,544.7 240,541.2 233.4,534.6L105.4,406.6C92.9,394.1 92.9,373.8 105.4,361.3 117.9,348.8 138.2,348.8 150.7,361.3L252.2,462.8 486.2,141.1C496.6,126.8,516.6,123.6,530.9,134z"
                                        Height="12"
                                        IsVisible="{Binding Theme, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource ThemeCompareConverter}, ConverterParameter='System'}"
                                        Width="12" />
                                    <TextBlock Text="跟随系统" />
                                </StackPanel>
                            </Button>
                            <Button
                                Click="ThemeMenuItem_OnClick"
                                Padding="8,4"
                                Tag="Light"
                                Theme="{StaticResource TransparentButton}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon
                                        Data="F1 M640,640z M0,0z M530.8,134.1C545.1,144.5,548.3,164.5,537.9,178.8L281.9,530.8C276.4,538.4 267.9,543.1 258.5,543.9 249.1,544.7 240,541.2 233.4,534.6L105.4,406.6C92.9,394.1 92.9,373.8 105.4,361.3 117.9,348.8 138.2,348.8 150.7,361.3L252.2,462.8 486.2,141.1C496.6,126.8,516.6,123.6,530.9,134z"
                                        Height="12"
                                        IsVisible="{Binding Theme, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource ThemeCompareConverter}, ConverterParameter='Light'}"
                                        Width="12" />
                                    <TextBlock Text="浅色" />
                                </StackPanel>
                            </Button>
                            <Button
                                Click="ThemeMenuItem_OnClick"
                                Padding="8,4"
                                Tag="Dark"
                                Theme="{StaticResource TransparentButton}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon
                                        Data="F1 M640,640z M0,0z M530.8,134.1C545.1,144.5,548.3,164.5,537.9,178.8L281.9,530.8C276.4,538.4 267.9,543.1 258.5,543.9 249.1,544.7 240,541.2 233.4,534.6L105.4,406.6C92.9,394.1 92.9,373.8 105.4,361.3 117.9,348.8 138.2,348.8 150.7,361.3L252.2,462.8 486.2,141.1C496.6,126.8,516.6,123.6,530.9,134z"
                                        Height="12"
                                        IsVisible="{Binding Theme, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource ThemeCompareConverter}, ConverterParameter='Dark'}"
                                        Width="12" />
                                    <TextBlock Text="深色" />
                                </StackPanel>
                            </Button>
                            <Button
                                Click="ThemeMenuItem_OnClick"
                                Padding="8,4"
                                Tag="Mirage"
                                Theme="{StaticResource TransparentButton}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon
                                        Data="F1 M640,640z M0,0z M530.8,134.1C545.1,144.5,548.3,164.5,537.9,178.8L281.9,530.8C276.4,538.4 267.9,543.1 258.5,543.9 249.1,544.7 240,541.2 233.4,534.6L105.4,406.6C92.9,394.1 92.9,373.8 105.4,361.3 117.9,348.8 138.2,348.8 150.7,361.3L252.2,462.8 486.2,141.1C496.6,126.8,516.6,123.6,530.9,134z"
                                        Height="12"
                                        IsVisible="{Binding Theme, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource ThemeCompareConverter}, ConverterParameter='Mirage'}"
                                        Width="12" />
                                    <TextBlock Text="幻影" />
                                </StackPanel>
                            </Button>
                            <Button
                                Click="BackgroundMode_OnClick"
                                Padding="8,4"
                                Tag="Acrylic"
                                Theme="{StaticResource TransparentButton}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon
                                        Data="F1 M640,640z M0,0z M530.8,134.1C545.1,144.5,548.3,164.5,537.9,178.8L281.9,530.8C276.4,538.4 267.9,543.1 258.5,543.9 249.1,544.7 240,541.2 233.4,534.6L105.4,406.6C92.9,394.1 92.9,373.8 105.4,361.3 117.9,348.8 138.2,348.8 150.7,361.3L252.2,462.8 486.2,141.1C496.6,126.8,516.6,123.6,530.9,134z"
                                        Height="12"
                                        IsVisible="{Binding BackgroundMode, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource BackgroundModeCompareConverter}, ConverterParameter='Acrylic'}"
                                        Width="12" />
                                    <TextBlock Text="亚克力" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                        <Border
                            IsVisible="{Binding BackgroundMode, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource BackgroundModeCompareConverter}, ConverterParameter='Acrylic'}">
                            <StackPanel Spacing="6">
                                <ColorPicker
                                    Color="{Binding BackgroundSolidColor, Source={x:Static const:Data.ConfigEntry}}"
                                    HorizontalAlignment="Stretch" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{DynamicResource SukiMuteText}"
                                    Text="亚克力不透明度" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <Slider
                                        Grid.Column="0"
                                        Maximum="1.0"
                                        Minimum="0.0"
                                        Value="{Binding AcrylicOpacity, Source={x:Static const:Data.ConfigEntry}}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="6,0,0,0"
                                        Text="{Binding AcrylicOpacity, Source={x:Static const:Data.ConfigEntry}, StringFormat={}{0:P0}}"
                                        VerticalAlignment="Center"
                                        Width="40" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Separator
                            Background="{DynamicResource PanelBorderBrush}"
                            Margin="0,4" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource SukiMuteText}"
                            Text="主窗口背景" />
                        <WrapPanel
                            HorizontalAlignment="Stretch"
                            Orientation="Horizontal">
                            <Button
                                Click="BackgroundMode_OnClick"
                                Padding="8,4"
                                Tag="Default"
                                Theme="{StaticResource TransparentButton}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon
                                        Data="F1 M640,640z M0,0z M530.8,134.1C545.1,144.5,548.3,164.5,537.9,178.8L281.9,530.8C276.4,538.4 267.9,543.1 258.5,543.9 249.1,544.7 240,541.2 233.4,534.6L105.4,406.6C92.9,394.1 92.9,373.8 105.4,361.3 117.9,348.8 138.2,348.8 150.7,361.3L252.2,462.8 486.2,141.1C496.6,126.8,516.6,123.6,530.9,134z"
                                        Height="12"
                                        IsVisible="{Binding BackgroundMode, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource BackgroundModeCompareConverter}, ConverterParameter='Default'}"
                                        Width="12" />
                                    <TextBlock Text="默认主题" />
                                </StackPanel>
                            </Button>
                            <Button
                                Click="BackgroundMode_OnClick"
                                Padding="8,4"
                                Tag="Image"
                                Theme="{StaticResource TransparentButton}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon
                                        Data="F1 M640,640z M0,0z M530.8,134.1C545.1,144.5,548.3,164.5,537.9,178.8L281.9,530.8C276.4,538.4 267.9,543.1 258.5,543.9 249.1,544.7 240,541.2 233.4,534.6L105.4,406.6C92.9,394.1 92.9,373.8 105.4,361.3 117.9,348.8 138.2,348.8 150.7,361.3L252.2,462.8 486.2,141.1C496.6,126.8,516.6,123.6,530.9,134z"
                                        Height="12"
                                        IsVisible="{Binding BackgroundMode, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource BackgroundModeCompareConverter}, ConverterParameter='Image'}"
                                        Width="12" />
                                    <TextBlock Text="图片" />
                                </StackPanel>
                            </Button>
                            <Button
                                Click="BackgroundMode_OnClick"
                                Padding="8,4"
                                Tag="SolidColor"
                                Theme="{StaticResource TransparentButton}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon
                                        Data="F1 M640,640z M0,0z M530.8,134.1C545.1,144.5,548.3,164.5,537.9,178.8L281.9,530.8C276.4,538.4 267.9,543.1 258.5,543.9 249.1,544.7 240,541.2 233.4,534.6L105.4,406.6C92.9,394.1 92.9,373.8 105.4,361.3 117.9,348.8 138.2,348.8 150.7,361.3L252.2,462.8 486.2,141.1C496.6,126.8,516.6,123.6,530.9,134z"
                                        Height="12"
                                        IsVisible="{Binding BackgroundMode, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource BackgroundModeCompareConverter}, ConverterParameter='SolidColor'}"
                                        Width="12" />
                                    <TextBlock Text="纯色" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                        <Border
                            IsVisible="{Binding BackgroundMode, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource BackgroundModeCompareConverter}, ConverterParameter='Image'}">
                            <StackPanel Spacing="6">
                                <tio:PathPicker
                                    FileFilter="[ImageAll]"
                                    SelectedPathsText="{Binding BackgroundImagePath, Source={x:Static const:Data.ConfigEntry}}"
                                    Title="选择背景图片"
                                    UsePickerType="OpenFile" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{DynamicResource SukiMuteText}"
                                    Text="{Binding BackgroundImagePath, Source={x:Static const:Data.ConfigEntry}}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap" />
                            </StackPanel>
                        </Border>
                        <Border
                            IsVisible="{Binding BackgroundMode, Source={x:Static const:Data.ConfigEntry}, Converter={StaticResource BackgroundModeCompareConverter}, ConverterParameter='SolidColor'}">
                            <ColorPicker
                                Color="{Binding BackgroundSolidColor, Source={x:Static const:Data.ConfigEntry}}"
                                HorizontalAlignment="Stretch" />
                        </Border>
                    </StackPanel>
                </tio:GlassCard>
            </Flyout>
        </Button.Flyout>
    </Button>
    <Separator
        Background="{DynamicResource ForegroundColor}"
        Height="18"
        IsVisible="{OnPlatform Default=True,
                               macOS=False}"
        Margin="5,0"
        Width="1" />
    <Button IsVisible="False" Name="AccountFlyout">
        <Button.Flyout>
            <Flyout VerticalOffset="5">
                <StackPanel Margin="10,0">
                    <DockPanel>
                        <TextBlock
                            DockPanel.Dock="Left"
                            FontSize="14"
                            HorizontalAlignment="Left"
                            Margin="0,5,0,10">
                            切换账户
                        </TextBlock>
                        <Button
                            Click="AddAcountButton_OnClick"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            Theme="{StaticResource TransparentButton}"
                            VerticalAlignment="Center">
                            <PathIcon
                                Data="F1 M1024,1024z M0,0z M512,832A32,32,0,0,0,544,800L544,544 800,544A32,32,0,0,0,800,480L544,480 544,224A32,32,0,0,0,480,224L480,480 224,480A32,32,0,0,0,224,544L480,544 480,800A32,32,0,0,0,512,832"
                                Height="21"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="21" />
                        </Button>
                    </DockPanel>
                    <tio:TioExpander
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1"
                        HeaderHeight="54"
                        IconHeight="14"
                        IconMargin="10,0,5,0"
                        IconWidth="18"
                        Margin="0,0,0,10"
                        VerticalAlignment="Top"
                        Width="250">
                        <tio:TioExpander.Header>
                            <StackPanel Orientation="Horizontal">
                                <Border
                                    ClipToBounds="True"
                                    CornerRadius="10"
                                    Height="36"
                                    Width="36">
                                    <Image
                                        Height="36"
                                        Source="{Binding Data.ConfigEntry.UsingMinecraftMinecraftAccount.Head}"
                                        Width="36" />
                                </Border>
                                <StackPanel Margin="7,0,0,0">
                                    <TextBlock Text="{Binding Data.ConfigEntry.UsingMinecraftMinecraftAccount.Name}" />
                                    <TextBlock FontSize="12" Text="{Binding Data.ConfigEntry.UsingMinecraftMinecraftAccount.DisplayAccountNote}" />
                                </StackPanel>
                            </StackPanel>
                        </tio:TioExpander.Header>
                        <StackPanel>
                            <Separator Background="{DynamicResource PopupBorderBrush}" HorizontalAlignment="Stretch" />
                            <ListBox
                                DockPanel.Dock="Bottom"
                                ItemsSource="{Binding Data.ConfigEntry.MinecraftAccounts}"
                                Margin="5"
                                SelectedItem="{Binding Data.ConfigEntry.UsingMinecraftMinecraftAccount}">

                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem Button.delete-btn">
                                        <Setter Property="Opacity" Value="0" />
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover Button.delete-btn">
                                        <Setter Property="Opacity" Value="1" />
                                    </Style>
                                </ListBox.Styles>

                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="account:MinecraftAccount">
                                        <Grid Background="Transparent" ColumnDefinitions="Auto, *, Auto">

                                            <Border
                                                ClipToBounds="True"
                                                CornerRadius="10"
                                                Grid.Column="0"
                                                Height="36"
                                                Margin="2,0,10,0"
                                                Width="36">
                                                <Image
                                                    Height="36"
                                                    Source="{Binding Head}"
                                                    Width="36" />
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <TextBlock
                                                        FontSize="14"
                                                        Text="{Binding Name}"
                                                        VerticalAlignment="Bottom" />
                                                    <TextBlock
                                                        FontSize="11"
                                                        Text="{Binding DisplayAccountNote}"
                                                        VerticalAlignment="Bottom" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <TextBlock FontSize="11" VerticalAlignment="Bottom">
                                                        <Run Text="上次登录时间" />
                                                        <Run Text=": " />
                                                        <Run Text="{Binding DisplayLastLoginTime}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>

                                            <tio:PopConfirm
                                                ConfirmCommand="{Binding #Root.DeleteAccountCommand}"
                                                ConfirmCommandParameter="{Binding}"
                                                Grid.Column="2"
                                                HorizontalAlignment="Left"
                                                Margin="5,0"
                                                Placement="BottomEdgeAlignedLeft"
                                                PopupContent="此修改将不可逆"
                                                PopupHeader="是否要移除此账户？"
                                                VerticalAlignment="Center">
                                                <Button Classes="delete-btn" Theme="{StaticResource TransparentButton}">
                                                    <PathIcon
                                                        Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                        Height="14"
                                                        Width="14" />
                                                    <Button.Transitions>
                                                        <Transitions>
                                                            <DoubleTransition Duration="0:0:0.1" Property="Opacity" />
                                                        </Transitions>
                                                    </Button.Transitions>
                                                </Button>
                                            </tio:PopConfirm>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </tio:TioExpander>
                </StackPanel>
            </Flyout>
        </Button.Flyout>
    </Button>
</StackPanel>