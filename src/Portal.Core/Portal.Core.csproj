<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
    </PropertyGroup>

    <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
        <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
        <DefineConstants>WINDOWS</DefineConstants>
    </PropertyGroup>

    <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
        <TargetFramework>net10.0</TargetFramework>
        <DefineConstants>LINUX</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="MinecraftLaunch" />
      <PackageReference Include="CommunityToolkit.Mvvm" />
      <PackageReference Include="MinecraftLaunch.Skin" />
      <PackageReference Include="SkiaSharp" />
    </ItemGroup>

    <ItemGroup>
      <Folder Include="Minecraft\Account\Authenticator\" />
      <Folder Include="Minecraft\Instance\Java\" />
      <Folder Include="Minecraft\Instance\Manifest\Bedrock\" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\module\LiteSkinViewer\LiteSkinViewer.2D\LiteSkinViewer.2D.csproj" />
      <ProjectReference Include="..\..\module\LiteSkinViewer\LiteSkinViewer.3D\LiteSkinViewer.3D.csproj" />
      <ProjectReference Include="..\..\module\LiteSkinViewer\LiteSkinViewer.Shared\LiteSkinViewer.Shared.csproj" />
      <ProjectReference Include="..\..\module\Tio.Avalonia.Standard\module\TioUi.Avalonia\src\TioUi\TioUi.csproj" />
      <ProjectReference Include="..\..\module\Tio.Avalonia.Standard\src\Tio.Avalonia.Standard.Tab\Tio.Avalonia.Standard.Tab.csproj" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Portal.Bedrock.Windows\Portal.Bedrock.Windows.csproj"
                          Condition="$([MSBuild]::IsOSPlatform('Windows'))"/>
    </ItemGroup>

</Project>
