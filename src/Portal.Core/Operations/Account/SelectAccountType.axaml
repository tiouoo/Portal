<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Core.Operations.Account.SelectAccountType"
    x:DataType="account:SelectAccountTypeViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:account="clr-namespace:Portal.Core.Operations.Account"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24" RowDefinitions="Auto, *, Auto">
        <TextBlock
            FontSize="16"
            FontWeight="600"
            Grid.Row="0"
            Text="添加新账户" />
        <tio:Form
            Grid.Row="1"
            HorizontalAlignment="Center"
            LabelPosition="Top"
            Margin="0,10,0,15">
            <tio:FormItem Label="账户类型">
                <StackPanel Spacing="4">
                    <DataValidationErrors>
                        <ComboBox
                            ItemsSource="{Binding AuthServers}"
                            SelectedItem="{Binding SelectedServer}"
                            Width="368"
                            tio:FocusHelper.DialogFocusHint="True">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayText}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </DataValidationErrors>
                </StackPanel>
            </tio:FormItem>
        </tio:Form>
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="8">
            <Button Command="{Binding CancelCommand}" Content="取消" />
            <!-- <Button Command="{Binding AddServerCommand}" Content="添加验证服务器" /> -->
            <Button Command="{Binding NextCommand}" Content="下一步" />
        </StackPanel>
    </Grid>
</UserControl>