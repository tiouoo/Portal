<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Core.Operations.Account.AuthServerDetected"
    x:DataType="account:AuthServerDetectedViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:account="clr-namespace:Portal.Core.Operations.Account"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid
        Margin="24"
        RowDefinitions="Auto, *, Auto"
        Width="510">
        <TextBlock
            FontSize="16"
            FontWeight="600"
            Grid.Row="0"
            Text="识别到验证服务器地址" />
        <StackPanel
            Grid.Row="1"
            Margin="0,10,0,15"
            Spacing="8">
            <TextBlock Text="{Binding ServerUrl}" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="8">
            <Button Command="{Binding CancelCommand}" Content="取消" />
            <Button Command="{Binding AddServerCommand}" Content="添加为验证服务器" />
            <Button Command="{Binding LoginCommand}" Content="登录账号" />
        </StackPanel>
    </Grid>
</UserControl>
